{
  "name": "zalo-auto-messenger",
  "version": "2.0.0",
  "description": "Multi-user Zalo Auto Messenger in Node.js/TypeScript with C native performance optimization",
  "main": "dist/server.js",
  "scripts": {
    "install-addon": "node-gyp rebuild",
    "build": "tsc && copyfiles -u 1 public/**/* dist/",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "https-proxy-agent": "^9.1.0",
    "socks-proxy-agent": "^8.0.4",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "zca-js": "^2.1.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.9",
    "@types/node-cron": "^3.0.11",
    "copyfiles": "^2.4.1",
    "node-gyp": "^10.1.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.2"
  }
}
