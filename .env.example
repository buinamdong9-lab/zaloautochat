# ============================================
# Zalo Auto Messenger - Environment Variables
# ============================================
# Copy file này thành .env và điền thông tin
# copy .env.example .env

# --- Zalo Credentials ---
# Lấy từ browser extension (xem README)
ZALO_IMEI=your_imei_here
ZALO_COOKIES={"zpw_enk":"...","zpw_sek":"..."}

# Số điện thoại Zalo (dùng để init client)
ZALO_PHONE=0901234567
ZALO_PASSWORD=

# --- Nhóm Chat ---
# Group ID (lấy từ URL hoặc extension - xem README)
GROUP_ID=your_group_id_here

# Nội dung tin nhắn gửi mỗi ngày
MESSAGE_CONTENT=Nhắc nhở điểm danh! 📋

# --- Schedule Settings ---
# Giờ gửi tin nhắn (24h format)
SEND_HOUR=7
SEND_MINUTE=0

# Timezone
TIMEZONE=Asia/Ho_Chi_Minh

# --- Retry Settings ---
MAX_RETRIES=3
RETRY_DELAY=10

# --- Logging ---
LOG_LEVEL=INFO
